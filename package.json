{
  "name": "fastify-hylafax-gateway",
  "version": "1.0.0",
  "description": "A modern Node.js bridge between web applications and HylaFax servers",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "build": "npm run clean && tsc",
    "clean": "rimraf lib"
  },
  "keywords": [
    "fax",
    "hylafax",
    "fastify",
    "api",
    "gateway"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/auth": "^4.4.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/env": "^4.3.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.3",
    "html-pdf-node": "^1.0.8",
    "markdown-pdf": "^11.0.0",
    "node-fetch": "^3.3.2",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "puppeteer": "^22.11.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.5",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
