# Server Configuration
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
ENABLE_SWAGGER=true

# Security
API_KEYS=key1,key2,key3
CORS_ORIGIN=*

# HylaFAX+ Configuration
HYLAFAX_HOST=localhost
HYLAFAX_PORT=4559
HYLAFAX_USER=faxuser
HYLAFAX_PASSWORD=faxpass
HYLAFAX_USE_SSL=false
MAX_RETRIES=12
DEFAULT_RESOLUTION=medium    # low, medium, high
DEFAULT_PRIORITY=127         # 0-255, higher is higher priority

# Upload Limits
MAX_FILE_SIZE=10485760  # 10MB

# Storage
STORAGE_DIR=/tmp/faxjsgw
